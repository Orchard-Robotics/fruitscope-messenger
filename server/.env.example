# Copy to .env. Local dev uses the Docker Postgres from docker-compose.yml.
DATABASE_URL="postgresql://verdant:verdant@localhost:5432/verdant?schema=public"

# Server port (optional, defaults to 3001 locally; Cloud Run sets 8080)
# PORT=3001

# --- "Sign in with FruitScope" (OIDC) ---
# Prod values are injected by Terraform; these are the local-dev defaults.
# OIDC_ISSUER="https://login.fruitscope.com"
# OIDC_CLIENT_ID="fruitscope-messenger"
# OIDC_CLIENT_SECRET="…"                       # confidential client secret
# OIDC_REDIRECT_URI="https://fruitscope-messenger.com/api/auth/callback"
# APP_URL="https://fruitscope-messenger.com"   # public origin (cookie Secure + redirects)
# SUPERADMIN_ORCHARD_CODE="orchard-robotics"   # where super admins land
# SUPERADMIN_ORCHARD_NAME="Orchard Robotics"

# --- Profile pictures (object storage) ---
# Local dev uses the fake-gcs emulator from docker-compose (service `gcs`).
# Prod values are injected by Terraform (real GCS bucket + CDN).
GCS_EMULATOR_HOST="http://localhost:4443"        # unset in prod (uses ADC + real GCS)
GCS_MEDIA_BUCKET="fruitscope-media"              # prod: <project>-verdant-media
MEDIA_PUBLIC_BASE="http://localhost:4443/fruitscope-media"  # prod: https://fruitscope-messenger.com

# Local-only: forge a session without the real IdP (POST /api/auth/dev-login).
# Hard-gated to non-production. Lets you exercise the UI + orchard switcher.
# ALLOW_DEV_LOGIN=true

# Local-only: allow the OIDC issuer over plain http:// (e.g. a provider running
# at http://localhost:9000). Hard-gated to non-production. TLS is always required
# in prod.
# OIDC_ALLOW_INSECURE=true
