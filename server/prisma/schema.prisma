// FruitScope Messenger schema.
//
// Multi-tenant: every Channel/DM/Message belongs to an Orchard, so each orchard
// has a fully isolated chat environment (like a Slack workspace).
//
// PostgreSQL everywhere: a local Docker Postgres for development
// (see docker-compose.yml) and GCP Cloud SQL in production. DATABASE_URL
// selects the target; migrations live in prisma/migrations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Orchard {
  id        String   @id
  code      String   @unique
  name      String
  createdAt DateTime @default(now())

  members  OrchardMembership[]
  channels Channel[]
  sessions Session[]
}

model OrchardMembership {
  orchardId String
  userId    String
  role      String   @default("member")
  joinedAt  DateTime @default(now())

  orchard Orchard @relation(fields: [orchardId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([orchardId, userId])
}

model User {
  id          String   @id
  // The OIDC `sub` (FruitScope user id) — the stable identity key. Every user is
  // provisioned from a "Sign in with FruitScope" login, so this is always set.
  oidcSub     String   @unique
  username    String   @unique
  displayName String
  email       String?
  // Mirrors the `fruitscope.is_admin` claim. Super admins land on the
  // orchard-robotics namespace and may switch into any other orchard.
  isSuperAdmin Boolean @default(false)
  hue         Int
  status      String   @default("offline")
  createdAt   DateTime @default(now())

  orchards        OrchardMembership[]
  memberships     ChannelMember[]
  messages        Message[]
  reactions       Reaction[]
  sessions        Session[]
  reads           Read[]
  createdChannels Channel[]           @relation("ChannelCreator")
}

model Channel {
  id          String   @id
  orchardId   String
  kind        String // "channel" | "dm"
  name        String
  topic       String   @default("")
  isPrivate   Boolean  @default(false)
  createdById String
  createdAt   DateTime @default(now())

  orchard   Orchard         @relation(fields: [orchardId], references: [id], onDelete: Cascade)
  createdBy User            @relation("ChannelCreator", fields: [createdById], references: [id])
  members   ChannelMember[]
  messages  Message[]
  reads     Read[]

  @@index([orchardId])
}

model ChannelMember {
  channelId String
  userId    String
  joinedAt  DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([channelId, userId])
}

model Message {
  id        String    @id
  channelId String
  authorId  String
  content   String
  createdAt DateTime  @default(now())
  editedAt  DateTime?

  channel   Channel    @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author    User       @relation(fields: [authorId], references: [id])
  reactions Reaction[]

  @@index([channelId, createdAt, id])
}

model Reaction {
  id        String @id @default(cuid())
  messageId String
  userId    String
  emoji     String

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}

model Session {
  token     String   @id
  userId    String
  orchardId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orchard Orchard @relation(fields: [orchardId], references: [id], onDelete: Cascade)
}

model Read {
  userId     String
  channelId  String
  lastReadAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@id([userId, channelId])
}
