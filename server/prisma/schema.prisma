// FruitScope Messenger schema.
//
// Multi-tenant: every Channel/DM/Message belongs to an Orchard, so each orchard
// has a fully isolated chat environment (like a Slack workspace).
//
// PostgreSQL everywhere: a local Docker Postgres for development
// (see docker-compose.yml) and GCP Cloud SQL in production. DATABASE_URL
// selects the target; migrations live in prisma/migrations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Orchard {
  id        String   @id
  code      String   @unique
  name      String
  createdAt DateTime @default(now())

  members  OrchardMembership[]
  channels Channel[]
  sessions Session[]
}

model OrchardMembership {
  orchardId String
  userId    String
  role      String   @default("member")
  joinedAt  DateTime @default(now())

  orchard Orchard @relation(fields: [orchardId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([orchardId, userId])
}

model User {
  id          String   @id
  // The OIDC `sub` (FruitScope user id) — the stable identity key. Every user is
  // provisioned from a "Sign in with FruitScope" login, so this is always set.
  oidcSub     String   @unique
  username    String   @unique
  displayName String
  email       String?
  // Mirrors the `fruitscope.is_admin` claim. Super admins land on the
  // orchard-robotics namespace and may switch into any other orchard.
  isSuperAdmin Boolean @default(false)
  // True for the built-in Canary AI assistant — a global bot present in every
  // orchard. The client renders its DM as the embedded Canary chat panel rather
  // than a normal message thread, and never shows it a composer of its own.
  isBot       Boolean @default(false)
  // The FruitScope OIDC `session_jwt` claim: a short-lived (24h) bearer token
  // that lets the messenger act as this user against the FruitScope API (Canary).
  // Presented to api.fruitscope.com as the `auth_jwt` cookie. Re-minted on every
  // login; null for the Canary bot and any non-OIDC (dev-login) user. Server-side
  // only — it is NEVER sent to the browser.
  fruitscopeAuthJwt          String?
  fruitscopeAuthJwtExpiresAt DateTime?
  // Fallback cache of the user's accessible orchards ([{code,name}]) — the last
  // successful FruitScope /user-info result, seeded at login from the OIDC claim.
  // Used ONLY to keep the Canary orchard picker working when /user-info is
  // unreachable; FruitScope stays the source of truth and the access gate.
  fruitscopeOrchardsCache    Json?
  hue         Int
  // GCS object key of the uploaded profile picture (e.g. "avatars/<id>-<rand>.webp"),
  // or null for none. The public URL is built from MEDIA_PUBLIC_BASE at read time
  // so storage/CDN host changes don't require a data migration.
  avatarKey   String?
  status      String   @default("offline")
  createdAt   DateTime @default(now())

  orchards        OrchardMembership[]
  memberships     ChannelMember[]
  messages        Message[]
  reactions       Reaction[]
  sessions        Session[]
  reads           Read[]
  createdChannels Channel[]           @relation("ChannelCreator")
}

model Channel {
  id          String   @id
  orchardId   String
  kind        String // "channel" | "dm"
  name        String
  topic       String   @default("")
  isPrivate   Boolean  @default(false)
  createdById String
  createdAt   DateTime @default(now())

  orchard   Orchard         @relation(fields: [orchardId], references: [id], onDelete: Cascade)
  createdBy User            @relation("ChannelCreator", fields: [createdById], references: [id])
  members   ChannelMember[]
  messages  Message[]
  reads     Read[]

  @@index([orchardId])
}

model ChannelMember {
  channelId String
  userId    String
  joinedAt  DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([channelId, userId])
}

model Message {
  id        String    @id
  channelId String
  authorId  String
  content   String
  createdAt DateTime  @default(now())
  editedAt  DateTime?

  channel   Channel    @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author    User       @relation(fields: [authorId], references: [id])
  reactions Reaction[]

  @@index([channelId, createdAt, id])
}

model Reaction {
  id        String @id @default(cuid())
  messageId String
  userId    String
  emoji     String

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}

model Session {
  token     String   @id
  // The real signed-in user + their orchard. These never change while a session
  // is masquerading — they identify the actual admin so we can restore + audit.
  userId    String
  orchardId String
  // Masquerade: when a (super) admin is "viewing as" another user, the session
  // ACTS as masqueradeUserId in masqueradeOrchardId. The effective identity is
  // the masquerade fields when set, else userId/orchardId.
  masqueradeUserId    String?
  masqueradeOrchardId String?
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orchard Orchard @relation(fields: [orchardId], references: [id], onDelete: Cascade)
}

model Read {
  userId     String
  channelId  String
  lastReadAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@id([userId, channelId])
}
